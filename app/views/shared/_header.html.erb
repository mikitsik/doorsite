<header class="main-header">
  <div class="container">
    <div class="main-header__inner">
      <%= link_to root_path, class: "logo" do %>
        <span class="logo__blue">Дверной.</span><span class="logo__orange">бел</span>
      <% end %>

      <%= form_with url: products_path,
                    method: :get,
                    data: {
                      controller: "catalog-filter",
                      turbo_frame: "catalog_frame"
                    },
                    class: "search-form" do %>
        <%= hidden_field_tag :brand, params[:brand], data: { catalog_filter_target: "brandField" } %>

        <%= text_field_tag :q,
                          params[:q],
                          placeholder: "Поиск дверей...",
                          class: "search-input",
                          data: { action: "input->catalog-filter#submitDebounced" } %>

        <button class="search-button" type="submit" aria-label="Поиск">
          <%= inline_svg_tag "icons/search.svg" %>
        </button>
      <% end %>

      <%= render "shared/call_dropdown" %>
    </div>
  </div>
</header>
