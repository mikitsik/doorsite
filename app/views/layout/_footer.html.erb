<section class="cta-section">
  <div class="container cta-section__inner">
    <h2>Нужна помощь с выбором двери? Подберём подходящий вариант под ваш интерьер и бюджет</h2>

    <p>
      Позвоните нам, и мы подберём подходящий вариант под ваш интерьер,
      бюджет и размеры проёма.
    </p>

    <div class="cta-section__phones">
      <a href="tel:">+375 (29) ***-**-**</a>
      <a href="tel:">+375 (29) ***-**-**</a>
    </div>

    <div class="cta-section__actions">
      <%= render "shared/call_dropdown" %>
      <a href="#catalog" class="btn btn--light">Открыть каталог</a>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer__inner">
    <a href="<%= root_path %>" class="footer__logo">
      <span class="footer__logo-dark">Дверной.</span><span class="footer__logo-light">бел</span>
    </a>

    <nav class="footer__nav">
      <a href="#catalog">Каталог</a>
      <a href="#catalog">Комплекты</a>
      <a href="#catalog">Каталог +</a>
      <a href="#catalog">Контакты</a>
    </nav>
  </div>

  <div class="container footer__bottom">
    © 2026 Дверной.бел * Все права защищены
  </div>
</footer>
