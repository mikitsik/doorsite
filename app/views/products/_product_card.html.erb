<article class="product-card">
  <a href="<%= product_path(product) %>">
    <% if product.image_url.present? %>
      <%= image_tag product.image_url, alt: product.title, loading: "lazy" %>
    <% else %>
      <div class="product-card__placeholder">Нет изображения</div>
    <% end %>
  </a>
</article>
