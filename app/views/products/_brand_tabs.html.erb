<% brand_links = [
  { name: "Elporta", href: "#catalog", class_name: "brand-link--elporta" },
  { name: "torex", href: "#catalog", class_name: "brand-link--torex" },
  { name: "dverimagna", href: "#catalog", class_name: "brand-link--dverimagna" },
  { name: "ЮРКАС", href: "#catalog", class_name: "brand-link--yurkas" }
] %>
<% brand_logos = {
  "brand-link--elporta" => { src: "brands/elporta.webp", alt: "Elporta" },
  "brand-link--torex" => { src: "brands/torex.webp", alt: "torex" },
  "brand-link--dverimagna" => { src: "brands/dverimagna.webp", alt: "dverimagna" },
  "brand-link--yurkas" => { src: "brands/jurkas.webp", alt: "ЮРКАС" }
} %>
<% brand_modifier_map = {
  "brand-link--elporta" => "btn__brand-elporta",
  "brand-link--torex" => "btn__brand-torex",
  "brand-link--dverimagna" => "btn__brand-dverimagna",
  "brand-link--yurkas" => "btn__brand-yurkas"
} %>

<div class="brand-links">
  <% brand_links.each do |brand| %>
    <a href="<%= brand[:href] %>" class="btn btn__brand <%= brand_modifier_map[brand[:class_name]] %>">
      <% if (logo = brand_logos[brand[:class_name]]) %>
        <%= image_tag logo[:src], class: "brand-logo", alt: logo[:alt], loading: "lazy" %>
      <% else %>
        <span><%= brand[:name] %></span>
      <% end %>
    </a>
  <% end %>
</div>
