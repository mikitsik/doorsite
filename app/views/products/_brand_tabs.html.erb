<% brand_logos = {
  "brand-link--elporta" => { src: "brands/elporta.webp", alt: "Elporta" },
  "brand-link--torex" => { src: "brands/torex.webp", alt: "torex" },
  "brand-link--dverimagna" => { src: "brands/dverimagna.webp", alt: "dverimagna" },
  "brand-link--yurkas" => { src: "brands/jurkas.webp", alt: "ЮРКАС" }
} %>

<div class="brand-links">
  <% brand_links.each do |brand| %>
    <a href="<%= brand[:href] %>" class="brand-link <%= brand[:class_name] %>" data-action="click->catalog-animation#play">
      <% if (logo = brand_logos[brand[:class_name]]) %>
        <%= image_tag logo[:src], class: "brand-logo", alt: logo[:alt], loading: "lazy" %>
      <% else %>
        <span><%= brand[:name] %></span>
      <% end %>
    </a>
  <% end %>
</div>
