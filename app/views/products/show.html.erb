<style>
  .product-shell {
    max-width: var(--site-container);
    margin: 0 auto;
    padding: 28px 18px 80px;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    text-decoration: none;
    background: rgba(255,255,255,0.78);
    border: 1px solid var(--site-border);
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .back-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.08);
  }

  .brand-chip {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.72);
    border: 1px solid var(--site-border);
    color: var(--site-muted);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .product-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: 26px;
    align-items: start;
  }

  .media-card,
  .info-card,
  .details-card {
    border: 1px solid var(--site-border);
    border-radius: 34px;
    background: var(--site-panel);
    box-shadow: var(--site-shadow);
    backdrop-filter: blur(12px);
  }

  .media-card {
    overflow: hidden;
    position: relative;
    min-height: 720px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.92), rgba(239,235,227,0.96));
  }

  .media-card::before {
    content: "";
    position: absolute;
    inset: -80px auto auto -80px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    filter: blur(10px);
  }

  .media-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    min-height: 720px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 34px;
  }

  .product-image {
    width: 100%;
    max-width: 720px;
    max-height: 840px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 24px 40px rgba(0,0,0,0.10));
  }

  .product-empty {
    width: 100%;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--site-muted);
    font-size: 18px;
    text-align: center;
    padding: 24px;
  }

  .info-card {
    padding: 28px 26px 26px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    background: var(--site-panel-strong);
    border: 1px solid var(--site-border);
    color: var(--site-muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .product-title {
    margin: 0 0 16px 0;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .product-subtitle {
    margin: 0 0 22px 0;
    color: var(--site-muted);
    font-size: 17px;
    line-height: 1.6;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 22px;
  }

  .meta-item {
    border: 1px solid var(--site-border);
    border-radius: 20px;
    background: rgba(255,255,255,0.56);
    padding: 14px 15px;
  }

  .meta-label {
    font-size: 12px;
    color: var(--site-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 7px;
  }

  .meta-value {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.35;
  }

  .price-box {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid var(--site-border);
    border-radius: 24px;
    background: rgba(255,255,255,0.64);
    padding: 18px;
    margin-bottom: 20px;
  }

  .price-label {
    font-size: 13px;
    color: var(--site-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .price-value {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .availability {
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.86);
    border: 1px solid var(--site-border);
    color: var(--site-muted);
    font-size: 13px;
    font-weight: 600;
  }

  .phones {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .phone-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    background: rgba(255,255,255,0.82);
    border: 1px solid var(--site-border);
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .phone-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 26px rgba(0,0,0,0.08);
    background: rgba(255,255,255,0.96);
  }

  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .btn-primary {
    background: var(--site-accent);
    color: #fff;
    border: 1px solid rgba(0,0,0,0.15);
    box-shadow: 0 16px 34px rgba(0,0,0,0.16);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 44px rgba(0,0,0,0.22);
  }

  .btn-secondary {
    background: rgba(255,255,255,0.78);
    color: var(--site-text);
    border: 1px solid var(--site-border);
  }

  .btn-secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.08);
    background: rgba(255,255,255,0.96);
  }

  .details-card {
    margin-top: 26px;
    padding: 28px 26px;
  }

  .details-title {
    margin: 0 0 16px 0;
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .details-text {
    font-size: 17px;
    line-height: 1.8;
    color: #2a2a2a;
  }

  .details-text p {
    margin-top: 0;
  }

  @media (max-width: 1100px) {
    .product-grid {
      grid-template-columns: 1fr;
    }

    .media-card,
    .info-card,
    .details-card {
      border-radius: 28px;
    }

    .media-card,
    .media-inner {
      min-height: 540px;
    }
  }

  @media (max-width: 700px) {
    .product-shell {
      padding: 18px 14px 52px;
    }

    .info-card {
      padding: 22px 18px 20px;
    }

    .details-card {
      padding: 22px 18px;
    }

    .media-inner {
      padding: 22px;
    }

    .meta-grid {
      grid-template-columns: 1fr;
    }

    .price-box {
      display: block;
    }

    .availability {
      margin-top: 14px;
    }
  }
</style>

<div class="product-shell">
  <div class="topbar">
    <%= link_to root_path, class: "back-link" do %>
      <span>←</span>
      <span>Назад в каталог</span>
    <% end %>

    <div class="brand-chip">
      <%= @product.brand.presence || "Door Boutique" %>
    </div>
  </div>

  <div class="product-grid">
    <section class="media-card">
      <div class="media-inner">
        <% if @product.image_url.present? %>
          <img
            src="<%= @product.image_url %>"
            alt="<%= @product.title %>"
            class="product-image"
          >
        <% else %>
          <div class="product-empty">
            Изображение скоро появится
          </div>
        <% end %>
      </div>
    </section>

    <section class="info-card">
      <div class="eyebrow">
        <%= @product.category.presence || "Каталог дверей" %>
      </div>

      <h1 class="product-title">
        <%= @product.title %>
      </h1>

      <p class="product-subtitle">
        Спокойная современная эстетика, чистые линии и визуально выразительная модель для интерьера.
      </p>

      <div class="meta-grid">
        <div class="meta-item">
          <div class="meta-label">Бренд</div>
          <div class="meta-value"><%= @product.brand.presence || "Не указан" %></div>
        </div>

        <div class="meta-item">
          <div class="meta-label">Категория</div>
          <div class="meta-value"><%= @product.category.presence || "Не указана" %></div>
        </div>
      </div>

      <div class="price-box">
        <div>
          <div class="price-label">Стоимость</div>
          <div class="price-value">
            <% if @product.price.present? %>
              <%= number_with_precision(@product.price, precision: 2) %> <%= @product.currency %>
            <% else %>
              Цена по запросу
            <% end %>
          </div>
        </div>

        <div class="availability">
          Актуальная модель
        </div>
      </div>

      <div class="phones">
        <a class="phone-link" href="tel:+375292746333">+375 (29) 274-63-33</a>
        <a class="phone-link" href="tel:+375296885529">+375 (29) 688-55-29</a>
      </div>

      <div class="actions">
        <a class="btn-primary" href="tel:+375292746333">Позвонить</a>
        <%= link_to "Вернуться в каталог", root_path, class: "btn-secondary" %>
      </div>
    </section>
  </div>

  <% if @product.description.present? %>
    <section class="details-card">
      <h2 class="details-title">Описание</h2>

      <div class="details-text">
        <%= simple_format(@product.description) %>
      </div>
    </section>
  <% end %>
</div>
