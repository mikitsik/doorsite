<section class="show-product">
  <div class="container show-product__inner">
    <%= link_to "← Назад в каталог", root_path(anchor: "catalog"), class: "show-product__back" %>

    <div class="show-product__layout">
      <div class="show-product__gallery">
        <% if @product.image_url.present? %>
          <%= image_tag @product.image_url, class: "show-product__image", alt: @product.title %>
        <% else %>
          <div class="show-product__placeholder">Нет фото</div>
        <% end %>
      </div>

      <div class="show-product__summary">
        <p class="show-product__meta">
          <%= [@product.brand, @product.dealer].compact_blank.join(" · ") %>
        </p>

        <h1 class="show-product__title"><%= @product.title %></h1>

        <div class="show-product__price">
          <% if @product.price.present? %>
            <%= number_to_currency(@product.price, unit: "BYN", format: "%n %u") %>
          <% else %>
            Цена по запросу
          <% end %>
        </div>

        <div class="show-product__facts">
          <% if @product.use_case.present? %>
            <div><span>Назначение</span><strong><%= @product.use_case %></strong></div>
          <% end %>

          <% if @product.construction_type.present? %>
            <div><span>Конструкция</span><strong><%= @product.construction_type %></strong></div>
          <% end %>

          <% if @product.thermal_break.present? %>
            <div><span>Терморазрыв</span><strong>Да</strong></div>
          <% end %>

          <% if @product.glass.present? %>
            <div><span>Стекло</span><strong><%= @product.glass %></strong></div>
          <% end %>
        </div>

        <%= render "shared/call_dropdown" %>
      </div>
    </div>
  </div>
</section>
