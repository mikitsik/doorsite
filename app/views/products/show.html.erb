<style>
  .product-show-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  @media (max-width: 800px) {
    .product-show-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div style="max-width: 1200px; margin: 0 auto; padding: 32px 16px 60px;">
  <div style="margin-bottom: 24px;">
    <%= link_to "← Назад в каталог", root_path, style: "text-decoration: none;" %>
  </div>

  <div class="product-show-grid">
    <div>
      <% if @product.image_url.present? %>
        <img
          src="<%= @product.image_url %>"
          alt="<%= @product.title %>"
          style="width: 100%; max-width: 520px; height: auto; display: block; border: 1px solid #e5e5e5;"
        >
      <% else %>
        <div style="width: 100%; max-width: 520px; min-height: 520px; border: 1px solid #e5e5e5; display: flex; align-items: center; justify-content: center;">
          Нет изображения
        </div>
      <% end %>
    </div>

    <div>
      <div style="font-size: 14px; color: #666; margin-bottom: 10px;">
        <%= @product.brand %>
      </div>

      <h1 style="font-size: 34px; line-height: 1.2; margin: 0 0 20px 0;">
        <%= @product.title %>
      </h1>

      <div style="margin-bottom: 12px; font-size: 18px;">
        <strong>Бренд:</strong> <%= @product.brand %>
      </div>

      <div style="margin-bottom: 12px; font-size: 18px;">
        <strong>Категория:</strong> <%= @product.category %>
      </div>

      <div style="margin-bottom: 24px; font-size: 28px; font-weight: 700;">
        <% if @product.price.present? %>
          <%= number_with_precision(@product.price, precision: 2) %> <%= @product.currency %>
        <% else %>
          Цена по запросу
        <% end %>
      </div>

      <div style="margin-bottom: 24px; font-size: 18px; line-height: 1.7;">
        <div>
          <a href="tel:+375292746333" style="color: inherit; text-decoration: none;">
            +375 (29) 274-63-33
          </a>
        </div>
        <div>
          <a href="tel:+375296885529" style="color: inherit; text-decoration: none;">
            +375 (29) 688-55-29
          </a>
        </div>
      </div>

      <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px;">
        <a href="tel:+375292746333" class="button-link">
          Позвонить
        </a>

        <%= link_to "Назад в каталог", root_path, class: "button-link button-link--light" %>
      </div>

      <% if @product.description.present? %>
        <div style="padding-top: 20px; border-top: 1px solid #e5e5e5;">
          <h2 style="font-size: 22px; margin-bottom: 14px;">Описание</h2>
          <div style="font-size: 17px; line-height: 1.7;">
            <%= simple_format(@product.description) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
