<article class="category-card category-card--<%= position %> <%= "is-active" if local_assigns[:active] %>">
  <a href="<%= href %>" class="category-card__image-wrap">
    <%= image_tag image_name, class: "category-card__image", loading: "lazy", alt: title %>
  </a>

  <h3 class="category-card__title"><%= title %></h3>

  <div class="category-card__price-row">
    <div class="category-card__price"><%= price %></div>
    <%= render "shared/call_dropdown", dropdown_classes: "call-dropdown--right" %>
  </div>
</article>
