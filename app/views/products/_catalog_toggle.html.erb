<div class="catalog-section__actions">
  <% if @catalog_expanded %>
    <%= link_to "Свернуть",
      root_path(category: @active_category, anchor: "catalog"),
      class: "btn btn__card",
      data: { turbo_frame: "catalog" } %>
  <% else %>
    <%= link_to "Показать ещё",
      root_path(catalog: "full", category: @active_category, anchor: "catalog"),
      class: "btn btn__card",
      data: { turbo_frame: "catalog" } %>
  <% end %>
</div>
