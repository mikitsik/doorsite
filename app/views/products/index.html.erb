<div style="max-width: 1200px; margin: 0 auto; padding: 32px 16px 60px;">
  <h2 style="text-align: center; font-size: 28px; margin-bottom: 20px;">
    Elporta
  </h2>

  <h3 style="text-align: center; font-size: 22px; text-transform: uppercase; margin-bottom: 32px;">
    <%= @products.first.category %>
  </h3>

  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 2px solid #ddd;">
        </tr>
      </thead>

      <tbody>
        <% @products.each do |product| %>
          <tr
            onclick="window.location='<%= product_path(product) %>'"
            style="border-bottom: 1px solid #e5e5e5; cursor: pointer;"
            onmouseover="this.style.background='#f9f9f9'"
            onmouseout="this.style.background='white'"
          >
            <td style="padding: 12px 10px; width: 120px;">
              <% if product.image_url.present? %>
                <img
                  src="<%= product.image_url %>"
                  alt="<%= product.title %>"
                  style="width: 90px; height: 120px; object-fit: cover; display: block;"
                >
              <% end %>
            </td>

            <td style="padding: 12px 10px; vertical-align: top; font-weight: 600; text-align: center">
              <%= product.title %>
            </td>

            <td style="padding: 12px 10px; vertical-align: top; white-space: nowrap;">
              <% if product.price.present? %>
                <%= number_with_precision(product.price, precision: 2) %> <%= product.currency %>
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @show_more %>
    <div style="text-align: center; margin-top: 28px;">
      <%= link_to "Показать больше",
          root_path(limit: @visible_count + ProductsController::PRODUCTS_PER_PAGE),
          class: "button-link" %>
    </div>
  <% end %>
</div>
