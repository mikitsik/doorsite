<div class="page">
  <div class="topbar">
    <div class="container topbar__inner">
      <div class="topbar__left">
        <%= inline_svg_tag "icons/location.svg" %>
        <span>Молодечно Ошмяны Островец Минск</span>
      </div>

      <div class="topbar__phones">
        <a href="tel:+375292746333">
          <%= inline_svg_tag "icons/phone.svg" %>
          +375 (29) 274-63-33
        </a>
        <a href="tel:+375296685629">
          +375 (29) 668-56-29
        </a>
      </div>
    </div>
  </div>

  <header class="main-header">
    <div class="container main-header__inner">
      <%= link_to root_path, class: "logo" do %>
        <span class="logo__blue">Дверной.</span><span class="logo__orange">бел</span>
      <% end %>

      <div class="header-search">
        <%= form_with url: products_path,
                      method: :get,
                      data: {
                        controller: "catalog-filter",
                        turbo_frame: "catalog_frame"
                      },
                      class: "search-form" do %>
          <%= hidden_field_tag :brand, params[:brand], data: { catalog_filter_target: "brandField" } %>

          <%= text_field_tag :q,
                            params[:q],
                            placeholder: "Поиск дверей...",
                            class: "search-input",
                            data: { action: "input->catalog-filter#submitDebounced" } %>

          <button class="search-button" type="submit" aria-label="Поиск">
            <%= inline_svg_tag "icons/search.svg" %>
          </button>
        <% end %>
      </div>

      <%= render "shared/call_dropdown" %>
    </div>
  </header>

  <section class="hero" style="--hero-bg: url('<%= asset_path("hero-room.webp") %>');">
    <div class="container hero__inner">
      <div class="hero__content">
        <div class="hero__eyebrow">
          <span class="hero__eyebrow-badge">
            <span class="hero__eyebrow-icon">
              <%= inline_svg_tag "icons/brands.svg" %>
            </span>
            <span class="hero__eyebrow-text">Популярные бренды</span>
          </span>
        </div>

        <h1 class="hero__title">
          Современные двери для квартиры, дома и офиса
        </h1>

        <p class="hero__text">
          Премиум и эконом класс<br>
          Гарантия
        </p>

        <div class="hero__actions">
          <a href="#catalog" class="btn btn--blue">Смотреть каталог</a>
          <%= render "shared/call_dropdown" %>
        </div>
      </div>
    </div>
  </section>

  <section class="benefits">
    <div class="container benefits__grid">
      <div class="benefit-item">
        <span class="benefit-item__icon">
          <%= inline_svg_tag "icons/credit.svg" %>
        </span>
        <span class="benefit-item__text">Рассрочка 0% и кредит</span>
      </div>

      <div class="benefit-item">
        <span class="benefit-item__icon">
          <%= inline_svg_tag "icons/select.svg" %>
        </span>
        <span class="benefit-item__text">Подбор оптимального варианта</span>
      </div>

      <div class="benefit-item">
        <span class="benefit-item__icon">
          <%= inline_svg_tag "icons/mesure-delivery.svg" %>
        </span>
        <span class="benefit-item__text">Замер, доставка, чистый монтаж</span>
      </div>

      <div class="benefit-item">
        <span class="benefit-item__icon">
          <%= inline_svg_tag "icons/call.svg" %>
        </span>
        <span class="benefit-item__text">Консультация по телефону</span>
      </div>
    </div>
  </section>

  <section class="popular-categories">
    <div class="container">
      <h2>Популярные категории</h2>

      <div class="popular-categories__grid">
        <% @featured_categories.each_with_index do |item, index| %>
          <article class="category-card category-card--<%= index + 1 %>">
            <a href="<%= item[:href] %>" class="category-card__image-wrap">
              <%= image_tag item[:image_name], class: "category-card__image", loading: "lazy" %>
            </a>

            <div class="category-card__body">
              <div class="category-card__title-bar">
                <h3 class="category-card__title"><%= item[:title] %></h3>
              </div>

              <div class="category-card__price-row">
                <div class="category-card__price"><%= item[:price] %></div>
              </div>

              <div class="category-card__actions">
                <a href="<%= item[:href] %>" class="mini-action-button mini-action-button--catalog">
                  Подробнее
                </a>

                <%= render "shared/call_dropdown" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section class="catalog-section" id="catalog">
    <div class="container">
      <h2>Каталог дверей</h2>

      <div class="brand-links">
        <% @brand_links.each do |brand| %>
          <a href="<%= brand[:href] %>" class="brand-link <%= brand[:class_name] %>">
            <span><%= brand[:name] %></span>
          </a>
        <% end %>
      </div>

    </div>
  </section>

  <section class="how-to-order">
    <div class="container">
      <h2>Как заказать</h2>

      <div class="steps-grid">
        <% @steps.each do |step| %>
          <article class="step-card <%= step[:card_class] %>">
            <div class="step-card__number"><%= step[:number] %></div>
            <div class="step-card__content">
              <div class="step-card__title"><%= step[:title] %></div>
              <div class="step-card__text"><%= step[:text] %></div>

              <div class="step-card__actions">
                <a href="<%= step[:href] %>" class="btn btn--white btn--step">
                  <%= step[:button] %>
                </a>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-section__inner">
      <h2>Нужна помощь с выбором двери? Подберём подходящий вариант под ваш интерьер и бюджет</h2>

      <p>
        Позвоните нам, и мы подберём подходящий вариант под ваш интерьер,
        бюджет и размеры проёма.
      </p>

      <div class="cta-section__phones">
        <a href="tel:+375292746635">+375 (29) 274-66-35</a>
        <a href="tel:+375296685629">+375 (29) 668-56-29</a>
      </div>

      <div class="cta-section__actions">
        <%= render "shared/call_dropdown" %>
        <a href="#catalog" class="btn btn--light">Открыть каталог</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer__inner">
      <a href="<%= root_path %>" class="footer__logo">
        <span class="logo__blue">Дверной</span> <span class="logo__orange">бел</span>
      </a>

      <nav class="footer__nav">
        <a href="#catalog">Каталог</a>
        <a href="#catalog">Комплекты</a>
        <a href="#catalog">Каталог +</a>
        <a href="#catalog">Контакты</a>
      </nav>
    </div>

    <div class="container footer__bottom">
      © 2024 Дверной бел. Все права защищены.
    </div>
  </footer>
</div>
