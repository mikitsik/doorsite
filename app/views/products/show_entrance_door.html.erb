<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= raw product_json_ld(product: @product, url: request.original_url) %>
  </script>
<% end %>

<% content_for :title,
  "#{@product.title} — входная дверь купить | ДВЕРНОЙ.БЕЛ" %>

<% content_for :meta_description,
  [
    @product.title,
    @product.brand.presence,
    @product.category.presence,
    @product.price.present? ? "Цена от #{@product.price} #{@product.currency.presence || 'BYN'}" : nil,
    "Входные двери в каталоге ДВЕРНОЙ.БЕЛ: подбор, доставка и установка."
  ].compact.join(". ") %>

<% product_details = [ @product.use_case, @product.material ].filter { |value| value.present? } %>

<section class="product-show" id="page-content" data-controller="page-content">
  <div class="container">
    <div class="product-show__layout">
      <div class="product-show__summary">
        <%= link_to "← Назад", "javascript:history.back()",
                    class: "btn btn--light product-show__back" %>

        <p class="product-show__meta"><%= @product.brand %></p>

        <h1 class="product-show__title"><%= @product.title %></h1>

        <div class="product-show__price">
          <% if @product.price.present? %>
            <%= number_to_currency(@product.price, unit: "руб", format: "%n %u") %>
          <% else %>
            Цена по запросу
          <% end %>
        </div>

        <% if product_details.any? %>
          <dl class="product-show__details">
            <% product_details.each do |value| %>
              <p><%= value %></p>
            <% end %>
          </dl>
        <% end %>
      </div>

      <div class="product-show__media">
        <% if @product.image_url.present? %>
          <%= image_tag @product.image_url, class: "product-show__image", alt: @product.title %>
        <% else %>
          <div class="product-show__placeholder">Нет фото</div>
        <% end %>
      </div>

      <% if @product.description.present? %>
        <div
          class="product-show__description"
          data-controller="description-toggle"
          data-description-toggle-expanded-class="is-expanded"
        >
          <h2>Описание</h2>

          <div
            class="product-show__description-content"
            data-description-toggle-target="content"
          >
            <%= simple_format(@product.description) %>
          </div>

          <button
            type="button"
            class="btn btn--light product-show__description-toggle"
            data-action="description-toggle#toggle"
            data-description-toggle-target="button"
            aria-expanded="false"
            hidden
          >
            Показать больше
          </button>
        </div>
      <% end %>
    </div>
  </div>
</section>
