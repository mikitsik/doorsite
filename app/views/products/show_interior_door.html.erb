<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= raw product_json_ld(product: @product, url: request.original_url) %>
  </script>
<% end %>

<% content_for :title, @product.seo_title %>

<% content_for :meta_description,
  [
    @product.display_title,
    @product.brand.presence,
    @product.series.present? ? "Серия #{@product.series}" : nil,
    @product.vendor_color.present? ? "Цвет #{@product.vendor_color}" : nil,
    @product.source_price.present? ? "Цена от #{@product.source_price} BYN" : nil,
    "Межкомнатные двери в каталоге ДВЕРНОЙ.БЕЛ: подбор, доставка и установка."
  ].compact.join(". ") %>

<%
  product_image_url =
    @product.image_original_url.presence ||
    @product.image_medium_url.presence ||
    @product.image_url.presence ||
    @product.image_thumbnail_url

  product_specs = [
    ["Серия", @product.series],
    ["Материал", @product.material],
    ["Стекло", @product.glass],
    ["Цвет", @product.vendor_color],
    ["Оттенок", @product.hint_tone]
  ].select { |_label, value| value.present? }
%>

<div id="page-content" data-controller="page-content">
  <%= turbo_frame_tag "product_show" do %>
    <section class="product-show product-show--interior">
      <div class="container">
        <div class="product-show__layout">
          <div class="product-show__summary">
            <%= link_to "javascript:history.back()", class: "product-show__back back_top" do %>
              <%= inline_svg_tag "icons/back-arrow.svg", class: "product-show__back-icon" %>
              <span class="product-show__back-label">в каталог</span>
            <% end %>

            <p class="product-show__meta"><%= @product.brand %></p>

            <h1 class="product-show__title"><%= @product.display_title %></h1>

            <div class="product-show__price">
              <% if @product.source_price.present? %>
                <%= number_to_currency(@product.source_price, unit: "руб", format: "%n %u") %>
              <% else %>
                Цена по запросу
              <% end %>
            </div>

            <% if product_specs.any? %>
              <% product_specs.each do |label, value| %>
                <div class="product-show__spec">
                  <p class="product-show__spec-name"><%= label %></p>
                  <p class="product-show__spec-value"><%= value %></p>
                </div>
              <% end %>
            <% end %>

            <% if @variants.any? %>
              <p class="product-show__spec-name">Варианты</p>
              <div class="product-show__variant-list">
                <% @variants.each do |variant| %>
                  <%
                    variant_image_url =
                      variant.image_thumbnail_url.presence ||
                      variant.image_medium_url.presence ||
                      variant.image_url.presence ||
                      variant.image_original_url

                    variant_label = variant.vendor_color.presence || variant.series.presence || "Вариант"

                    variant_classes = ["product-show__variant"]
                    variant_classes << "is-active" if variant.id == @product.id
                  %>

                  <%= link_to interior_door_path(variant),
                              class: variant_classes.join(" "),
                              data: {
                                turbo_frame: "product_show",
                                turbo_action: "replace",
                                turbo_prefetch: false
                              } do %>
                    <% if variant_image_url.present? %>
                      <%= image_tag variant_image_url,
                                    class: "product-show__variant-thumb",
                                    alt: variant_label %>
                    <% end %>

                    <span class="product-show__variant-label"><%= variant_label %></span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="product-show__media">
            <% if product_image_url.present? %>
              <%= image_tag product_image_url, class: "product-show__image", alt: @product.display_title %>
            <% else %>
              <div class="product-show__placeholder">Нет фото</div>
            <% end %>
          </div>

          <% if @product.description.present? %>
            <div
              class="product-show__description"
              data-controller="description-toggle"
              data-description-toggle-expanded-class="is-expanded"
            >
              <h2>Описание</h2>

              <div
                class="product-show__description-content"
                data-description-toggle-target="content"
              >
                <%= simple_format(@product.description) %>
              </div>

              <button
                type="button"
                class="btn btn--light product-show__description-toggle"
                data-action="description-toggle#toggle"
                data-description-toggle-target="button"
                aria-expanded="false"
                hidden
              >
                Показать больше
              </button>
            </div>
          <% end %>
        </div>

        <%= link_to "javascript:history.back()", class: "product-show__back back_down" do %>
          <%= inline_svg_tag "icons/back-arrow.svg", class: "product-show__back-icon" %>
          <span class="product-show__back-label">в каталог</span>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
