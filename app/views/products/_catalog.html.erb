<%
  catalog_tabs = {
    "entrance_doors" => "Входные двери",
    "interior_doors" => "Межкомнатные двери",
    "system_doors" => "Дверные системы"
  }

  mobile_catalog_labels = {
    "entrance_doors" => "Входные",
    "interior_doors" => "Межкомнатные",
    "system_doors" => "Системы"
  }

  filter_labels = {
    "entrance_doors" => "Фильтры входных",
    "interior_doors" => "Фильтры межкомнатных",
    "system_doors" => "Фильтры систем"
  }

  mobile_filter_labels = {
    "entrance_doors" => "Фильтры входных дверей",
    "interior_doors" => "Фильтры межкомнатных дверей",
    "system_doors" => "Фильтры дверных систем"
  }
%>

<section class="catalog" id="catalog" data-controller="catalog-scroll">
  <turbo-frame id="catalog">
    <div class="container catalog__inner">

      <nav class="catalog-tabs" aria-label="Каталог дверей">
        <% catalog_tabs.each do |type, label| %>
          <%= link_to root_path(catalog_type: type, anchor: "catalog"),
                      class: "catalog-tabs__item #{'is-active' if @catalog_type == type}",
                      "aria-current": ("page" if @catalog_type == type) do %>
            <span class="catalog-tabs__label catalog-tabs__label--desktop">
              <%= label %></span>
            <span class="catalog-tabs__label catalog-tabs__label--mobile">
              <%= mobile_catalog_labels[type] %></span>
          <% end %>
        <% end %>
      </nav>

      <div data-controller="filters" class="catalog-filters">
        <button
          type="button"
          class="catalog-filters__toggle <%= 'is-open' if @filters_open %>"
          data-action="filters#toggle"
          data-filters-target="button"
        >
          <span class="catalog-filters__icon" aria-hidden="true">
            <svg viewBox="0 0 42 24" focusable="false">
              <path d="M3 6H39" />
              <path d="M3 12H39" />
              <path d="M3 18H39" />

              <circle class="catalog-filters__dot catalog-filters__dot--one" cx="14" cy="6" r="2.5" />
              <circle class="catalog-filters__dot catalog-filters__dot--two" cx="28" cy="12" r="2.5" />
              <circle class="catalog-filters__dot catalog-filters__dot--three" cx="20" cy="18" r="2.5" />
            </svg>
          </span>

          <span class="catalog-filters__link--desktop">
            <%= filter_labels[@catalog_type] || "Фильтры каталога" %>
          </span>
          <span class="catalog-filters__link--mobile">
            <%= mobile_filter_labels[@catalog_type] || "Фильтры каталога" %>
          </span>
        </button>

        <div
          class="catalog-filters__panel <%= "is-open" if @filters_open %>"
          data-filters-target="panel"
        >
          <%= render "products/filters/#{@catalog_type}_filter" %>
        </div>
      </div>

      <div class="catalog-grid">
        <% products.each_with_index do |product, index| %>
          <%
            card_title = product.try(:display_title).presence || product.try(:title).presence || product.try(:source_title)
            card_price = product.try(:price).presence || product.try(:source_price)
          %>
          <article class="product-card">
            <%= link_to catalog_product_path(product, anchor: "show"),
                        class: "product-card__image-wrap",
                        data: { turbo: false } do %>
              <% if product.image_url.present? %>
                <%= image_tag product.image_url,
                  class: "product-card__image",
                  loading: index < 4 ? "eager" : "lazy",
                  decoding: "async",
                  alt: card_title
                %>
              <% else %>
                <div class="product-card__placeholder">Нет фото</div>
              <% end %>
            <% end %>

            <div class="product-card__body">
              <div class="product-card__meta"><%= product.brand %></div>

              <h3 class="product-card__title">
                <%= link_to card_title,
                        catalog_product_path(product, anchor: "show"),
                        data: { turbo: false } %>
              </h3>

              <div class="product-card__price">
                <% if card_price.present? %>
                  от <%= number_to_currency(card_price, unit: "BYN", format: "%n %u") %>
                <% else %>
                  Цена по запросу
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <nav class="catalog-pagination" aria-label="Пагинация каталога">
          <% if @page > 1 %>
            <%= link_to "←",
                        root_path(catalog_type: @catalog_type, page: @page - 1, anchor: "catalog"),
                        class: "catalog-pagination__link catalog-pagination__link--arrow",
                        "aria-label": "Предыдущая страница" %>
          <% else %>
            <span class="catalog-pagination__link catalog-pagination__link--arrow is-disabled"
                  aria-disabled="true">←</span>
          <% end %>

          <% compact_pagination_pages(@page, @total_pages).each do |item| %>
            <% if item == :ellipsis %>
              <span class="catalog-pagination__ellipsis">…</span>
            <% else %>
              <%= link_to item,
                          root_path(catalog_type: @catalog_type, page: item, anchor: "catalog"),
                          class: "catalog-pagination__link #{'is-active' if item == @page}",
                          "aria-current": ("page" if item == @page) %>
            <% end %>
          <% end %>

          <% if @page < @total_pages %>
            <%= link_to "→",
                        root_path(catalog_type: @catalog_type, page: @page + 1, anchor: "catalog"),
                        class: "catalog-pagination__link catalog-pagination__link--arrow",
                        "aria-label": "Следующая страница" %>
          <% else %>
            <span class="catalog-pagination__link catalog-pagination__link--arrow is-disabled"
                  aria-disabled="true">→</span>
          <% end %>
        </nav>
      <% end %>
    </div>
  </turbo-frame>
</section>
