<%
  catalog_tabs = {
    "entrance_doors" => "Входные двери",
    "interior_doors" => "Межкомнатные двери",
    "system_doors" => "Дверные системы"
  }
  catalog_title = catalog_tabs.fetch(@catalog_type)
%>

<section class="catalog" id="catalog" data-controller="catalog-scroll">
  <turbo-frame id="catalog">
    <div class="container catalog__inner">

      <nav class="catalog__toolbar" aria-label="Тип каталога">
        <h2 class="catalog__title <%= 'is-active' if @catalog_type == 'entrance_doors' %>">
          <%= link_to "Входные двери",
                    root_path(catalog_type: "entrance_doors", anchor: "catalog"),
                    "aria-current": ("page" if @catalog_type == "entrance_doors") %></h2>

        <h2 class="catalog__title <%= 'is-active' if @catalog_type == 'interior_doors' %>">
          <%= link_to "Межкомнатные двери",
                    root_path(catalog_type: "interior_doors", anchor: "catalog"),
                    "aria-current": ("page" if @catalog_type == "interior_doors") %></h2>

        <h2 class="catalog__title <%= 'is-active' if @catalog_type == 'system_doors' %>">
          <%= link_to "Дверные системы",
                    root_path(catalog_type: "system_doors", anchor: "catalog"),
                    "aria-current": ("page" if @catalog_type == "system_doors") %></h2>
      </nav>

      <div data-controller="filters" class="catalog-filters">
        <button
          type="button"
          class="catalog-filters__toggle <%= 'is-open' if @filters_open %>"
          data-action="filters#toggle"
          data-filters-target="button"
        >
          Фильтры
        </button>

        <div
          class="catalog-filters__panel <%= "is-open" if @filters_open %>"
          data-filters-target="panel"
        >
          <%= render "products/filters/#{@catalog_type}" %>
        </div>
      </div>

      <div class="catalog-grid">
        <% @products.each do |product| %>
          <article class="product-card">
            <%= link_to catalog_product_path(product, anchor: "show"), class: "product-card__image-wrap", data: { turbo_frame: "_top" } do %>
              <% if product.image_url.present? %>
                <%= image_tag product.image_url, class: "product-card__image", loading: "lazy", alt: product.title %>
              <% else %>
                <div class="product-card__placeholder">Нет фото</div>
              <% end %>
            <% end %>

            <div class="product-card__body">
              <div class="product-card__meta"><%= product.brand %></div>

              <h3 class="product-card__title">
                <%= link_to product.title, catalog_product_path(product), data: { turbo_frame: "_top" } %>
              </h3>

              <div class="product-card__price">
                <% if product.price.present? %>
                  от <%= number_to_currency(product.price, unit: "BYN", format: "%n %u") %>
                <% else %>
                  Цена по запросу
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <nav class="catalog-pagination" aria-label="Пагинация каталога">
          <% if @page > 1 %>
            <%= link_to "←",
                        root_path(catalog_type: @catalog_type, page: @page - 1, anchor: "catalog"),
                        class: "catalog-pagination__link catalog-pagination__link--arrow",
                        "aria-label": "Предыдущая страница" %>
          <% else %>
            <span class="catalog-pagination__link catalog-pagination__link--arrow is-disabled"
                  aria-disabled="true">←</span>
          <% end %>

          <% compact_pagination_pages(@page, @total_pages).each do |item| %>
            <% if item == :ellipsis %>
              <span class="catalog-pagination__ellipsis">…</span>
            <% else %>
              <%= link_to item,
                          root_path(catalog_type: @catalog_type, page: item, anchor: "catalog"),
                          class: "catalog-pagination__link #{'is-active' if item == @page}",
                          "aria-current": ("page" if item == @page) %>
            <% end %>
          <% end %>

          <% if @page < @total_pages %>
            <%= link_to "→",
                        root_path(catalog_type: @catalog_type, page: @page + 1, anchor: "catalog"),
                        class: "catalog-pagination__link catalog-pagination__link--arrow",
                        "aria-label": "Следующая страница" %>
          <% else %>
            <span class="catalog-pagination__link catalog-pagination__link--arrow is-disabled"
                  aria-disabled="true">→</span>
          <% end %>
        </nav>
      <% end %>
    </div>
  </turbo-frame>
</section>
