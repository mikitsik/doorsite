<main>
  <section class="catalog" id="catalog">
    <div class="container catalog__inner">
      <div class="catalog__toolbar">
        <div>
          <p class="catalog__eyebrow">Каталог дверей</p>
          <h2 class="catalog__title">Входные двери</h2>
        </div>

        <div class="catalog-filters">
          <%= link_to root_path(anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'all'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "all" %>
            </span>

            Все
          <% end %>

          <%= link_to root_path(filter: "street", anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'street'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "street" %>
            </span>

            Уличные
          <% end %>

          <%= link_to root_path(filter: "thermal", anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'thermal'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "thermal" %>
            </span>

            С терморазрывом
          <% end %>

          <%= link_to root_path(filter: "apartment", anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'apartment'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "apartment" %>
            </span>

            Квартирные
          <% end %>

          <%= link_to root_path(filter: "glass", anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'glass'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "glass" %>
            </span>

            Со стеклом
          <% end %>

          <%= link_to root_path(filter: "metal_mdf", anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'metal_mdf'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "metal_mdf" %>
            </span>

            Металл-МДФ
          <% end %>

          <%= link_to root_path(filter: "mdf_mdf", anchor: "catalog"),
                      class: "catalog-filters__chip #{'is-active' if @active_filter == 'mdf_mdf'}" do %>
            <span class="catalog-filters__check">
              <%= "✓" if @active_filter == "mdf_mdf" %>
            </span>

            МДФ-МДФ
          <% end %>
        </div>

        <div class="catalog__count">
          <%= @total_products %> товаров
        </div>
      </div>

      <div class="catalog-grid">
        <% @products.each do |product| %>
          <article class="product-card">
            <%= link_to product_path(product), class: "product-card__image-wrap", data: { turbo_frame: "catalog" } do %>
              <% if product.image_url.present? %>
                <%= image_tag product.image_url, class: "product-card__image", loading: "lazy", alt: product.title %>
              <% else %>
                <div class="product-card__placeholder">Нет фото</div>
              <% end %>
            <% end %>

            <div class="product-card__body">
              <div class="product-card__meta"><%= product.brand %></div>

              <h3 class="product-card__title">
                <%= link_to product.title, product_path(product), data: { turbo_frame: "catalog" } %>
              </h3>

              <div class="product-card__price">
                <% if product.price.present? %>
                  от <%= number_to_currency(product.price, unit: "BYN", format: "%n %u") %>
                <% else %>
                  Цена по запросу
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <% if @total_pages > 1 %>
        <nav class="catalog-pagination" aria-label="Пагинация каталога">
          <% 1.upto(@total_pages) do |page| %>
            <%= link_to page,
                        root_path(filter: @active_filter, page: page, anchor: "catalog"),
                        class: "catalog-pagination__link #{'is-active' if page == @page}" %>
          <% end %>
        </nav>
      <% end %>
    </div>
  </section>
</main>
