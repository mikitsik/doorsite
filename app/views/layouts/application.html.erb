<!DOCTYPE html>
<html>
  <head>
    <title>DoorSite</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <style>
      :root {
        --text: #111111;
        --muted: #666666;
        --line: #e5e5e5;
        --bg: #ffffff;
      }

      * {
        box-sizing: border-box;
      }

      html {
        margin: 0;
        padding: 0;
      }

      body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Arial, Helvetica, sans-serif;
        font-size: 16px;
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      .site-header {
        border-bottom: 1px solid var(--line);
        padding: 20px 16px;
      }

      .site-header__inner {
        max-width: 1200px;
        margin: 0 auto;
        text-align: center;
      }

      .site-title {
        margin: 0 0 10px 0;
        font-size: 28px;
        line-height: 1.2;
        font-weight: 700;
        letter-spacing: 0.03em;
      }

      .site-phones {
        color: var(--muted);
        font-size: 18px;
        line-height: 1.7;
      }

      .site-main {
        min-height: calc(100vh - 180px);
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 24px 16px;
        margin-top: 40px;
      }

      .site-footer__inner {
        max-width: 1200px;
        margin: 0 auto;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
      }

      .button-link {
        display: inline-block;
        padding: 12px 22px;
        border: 1px solid #222;
        border-radius: 6px;
        text-decoration: none;
      }

      .button-link--light {
        border-color: #cccccc;
      }

      @media (max-width: 800px) {
        .site-title {
          font-size: 22px;
        }

        .site-phones {
          font-size: 16px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <h1 class="site-title">dveri_molodechno_region</h1>

        <div class="site-phones">
          <div>
            <a href="tel:+375292746333">+375 (29) 274-63-33</a>
          </div>
          <div>
            <a href="tel:+375296885529">+375 (29) 688-55-29</a>
          </div>
        </div>
      </div>
    </header>

    <main class="site-main">
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        dveri_molodechno_region 2026 &copy;
      </div>
    </footer>
  </body>
</html>
