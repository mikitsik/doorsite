<!DOCTYPE html>
<html lang="ru">
  <head>
    <title><%= content_for(:title) || "Дверной.бел" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <meta name="description" content="<%= content_for(:meta_description) || "Каталог межкомнатных и входных дверей" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% flash.each do |type, message| %>
      <div class="flash flash--<%= type %>">
        <%= message %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
