<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DoorSite" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <style>
      :root {
        --site-bg: #f6f4ef;
        --site-bg-2: #f3f0ea;
        --site-panel: rgba(255, 255, 255, 0.72);
        --site-panel-strong: rgba(255, 255, 255, 0.86);
        --site-border: rgba(0, 0, 0, 0.08);
        --site-text: #171717;
        --site-muted: #6b6b6b;
        --site-accent: #1f1f1f;
        --site-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
        --site-shadow-soft: 0 12px 30px rgba(0, 0, 0, 0.05);
        --site-radius-xl: 28px;
        --site-radius-lg: 20px;
        --site-radius-md: 14px;
        --site-container: 1320px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--site-text);
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255,255,255,0.9), transparent 32%),
          radial-gradient(circle at top right, rgba(255,255,255,0.72), transparent 28%),
          linear-gradient(180deg, #f8f6f1 0%, var(--site-bg-2) 100%);
      }

      a {
        color: inherit;
      }

      img {
        max-width: 100%;
      }

      .site-frame {
        position: relative;
        min-height: 100vh;
      }

      .site-header-wrap {
        position: sticky;
        top: 0;
        z-index: 50;
        padding: 14px 14px 0;
        backdrop-filter: blur(10px);
      }

      .site-header {
        max-width: var(--site-container);
        margin: 0 auto;
        padding: 12px 16px;
        border: 1px solid var(--site-border);
        border-radius: 999px;
        background: rgba(255,255,255,0.68);
        box-shadow: var(--site-shadow-soft);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .site-logo {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        min-width: 0;
      }

      .site-logo-mark {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1f1f1f, #4b4b4b);
        color: #fff;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.08em;
        box-shadow: 0 10px 24px rgba(0,0,0,0.16);
        flex: 0 0 auto;
      }

      .site-logo-text {
        min-width: 0;
      }

      .site-logo-title {
        font-size: 15px;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
      }

      .site-logo-subtitle {
        font-size: 12px;
        color: var(--site-muted);
        line-height: 1.2;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .site-nav-link,
      .site-phone {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid transparent;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
      }

      .site-nav-link {
        color: var(--site-muted);
      }

      .site-nav-link:hover {
        background: rgba(255,255,255,0.72);
        border-color: var(--site-border);
        transform: translateY(-1px);
      }

      .site-phone {
        background: rgba(255,255,255,0.82);
        border-color: var(--site-border);
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(0,0,0,0.05);
      }

      .site-phone:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px rgba(0,0,0,0.09);
        background: rgba(255,255,255,0.96);
      }

      .site-main {
        padding: 20px 0 0;
      }

      .flash-stack {
        max-width: var(--site-container);
        margin: 0 auto 18px;
        padding: 0 18px;
      }

      .flash {
        border: 1px solid var(--site-border);
        border-radius: 20px;
        padding: 14px 16px;
        background: rgba(255,255,255,0.78);
        box-shadow: var(--site-shadow-soft);
        margin-bottom: 10px;
      }

      .flash.notice {
        border-color: rgba(29, 113, 72, 0.18);
      }

      .flash.alert {
        border-color: rgba(145, 53, 53, 0.18);
      }

      .site-footer {
        padding: 26px 18px 34px;
      }

      .site-footer-inner {
        max-width: var(--site-container);
        margin: 0 auto;
        border-top: 1px solid rgba(0,0,0,0.08);
        padding-top: 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        color: var(--site-muted);
        font-size: 14px;
      }

      .site-footer-links {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .site-footer-link {
        text-decoration: none;
        padding: 8px 12px;
        border-radius: 999px;
        transition: background 0.2s ease, color 0.2s ease;
      }

      .site-footer-link:hover {
        background: rgba(255,255,255,0.7);
        color: var(--site-text);
      }

      @media (max-width: 900px) {
        .site-header {
          border-radius: 28px;
          align-items: flex-start;
          flex-direction: column;
        }

        .site-nav {
          width: 100%;
        }
      }

      @media (max-width: 700px) {
        .site-header-wrap {
          padding: 10px 10px 0;
        }

        .site-header {
          padding: 12px;
        }

        .site-logo-mark {
          width: 34px;
          height: 34px;
          font-size: 12px;
        }

        .site-logo-title {
          font-size: 14px;
        }

        .site-logo-subtitle {
          white-space: normal;
        }

        .site-main {
          padding-top: 14px;
        }

        .flash-stack {
          padding: 0 14px;
        }

        .site-footer {
          padding: 20px 14px 28px;
        }

        .site-footer-inner {
          display: block;
        }

        .site-footer-links {
          margin-top: 10px;
        }
      }
    </style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="site-frame">
      <div class="site-header-wrap">
        <header class="site-header">
          <%= link_to root_path, class: "site-logo" do %>
            <span class="site-logo-mark">DS</span>

            <span class="site-logo-text">
              <span class="site-logo-title">dveri_molodechno_region</span>
            </span>
          <% end %>

          <nav class="site-nav">
            <a href="tel:+375292746333" class="site-phone">+375 (29) 274-63-33</a>
            <a href="tel:+375296885529" class="site-phone">+375 (29) 688-55-29</a>
          </nav>
        </header>
      </div>

      <main class="site-main">
        <% if notice.present? || alert.present? %>
          <div class="flash-stack">
            <% if notice.present? %>
              <div class="flash notice"><%= notice %></div>
            <% end %>

            <% if alert.present? %>
              <div class="flash alert"><%= alert %></div>
            <% end %>
          </div>
        <% end %>

        <%= yield %>
      </main>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <div>
            dveri_molodechno_region 2026 &copy;
          </div>

          <div class="site-footer-links">
            <%= link_to "Каталог", root_path, class: "site-footer-link" %>
            <a href="tel:+375292746333" class="site-footer-link">Позвонить</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
