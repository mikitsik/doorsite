<!DOCTYPE html>
<html lang="ru">
  <head>
    <title><%= content_for(:title) || "Дверной.бел" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <meta name="description" content="<%= content_for(:meta_description) || "Каталог межкомнатных и входных дверей" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= favicon_link_tag "favicon.ico" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="catalog-animation">
    <%= render "layout/flash" %>
    <%= render "layout/header" %>

    <%= yield %>

    <%= render "layout/footer" %>
    <%= render "shared/catalog_animation_layer" %>
  </body>
</html>
